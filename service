#!/usr/bin/python2.7
# -*- coding: utf-8 -*-
#
# Infotext Player - Service-Sidecar
#
# info-beamer-Lua-Knoten koennen kein HTTP. Dieser Sidecar laeuft als
# Python-Prozess parallel zum Knoten, pollt regelmaessig die M3U8-
# Playlist + Folien-Bilder vom Infotext-Server und schreibt die
# heruntergeladenen Folien direkt in das Knoten-Verzeichnis. Eine
# manifest.json mit der aktuellen Folienliste wird via util.json_watch
# vom node.lua beobachtet.
#
# Folien-Files erhalten den Praefix SLIDE_PREFIX, damit sie sich klar
# von den Knoten-eigenen Dateien (node.lua, node.json, empty.png, ...)
# unterscheiden lassen. Ein Cache-Unterverzeichnis vermeiden wir, weil
# info-beamer Folien aus zur Laufzeit befuellten Subdirs nicht
# zuverlaessig findet (Subdir = Child-Node).
#
# Konfiguration kommt aus config.json (gleicher Pfad wie fuer Lua).
# Der Service liest sie in jeder Schleifen-Iteration neu, damit
# Setup-Aenderungen ohne Neustart wirken.

import os
import sys
import json
import time
import socket
import hashlib
import traceback
import datetime

# Python-2-Importpfade — der Sidecar-Shebang oben ist /usr/bin/python2.7.
from urlparse import urlsplit, urljoin
from urllib   import unquote

import requests
import urllib3
import pytz

SLIDE_PREFIX = "slide_"
MANIFEST     = "manifest.json"
CONFIG       = "config.json"

# UDP-IPC zu info-beamer auf dem Standard-Port. Wird fuer das Push
# des Zeit-Texts an den Lua-Knoten verwendet, statt eine Datei auf
# der SD-Karte zu schreiben (~86k Writes/Tag bei sekundengenauer
# Anzeige würden die SD unnoetig belasten).
IB_HOST   = "127.0.0.1"
IB_PORT   = 4444
_ipc_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)


def log(msg):
    sys.stderr.write("[infotext-service] %s\n" % msg)
    sys.stderr.flush()


def load_config():
    try:
        with open(CONFIG) as f:
            return json.load(f)
    except Exception as e:
        log("config.json konnte nicht gelesen werden: %s" % e)
        return {}


# urllib3 InsecureRequestWarning ist Process-global "klebrig" — einmal
# disabled bleibt sie disabled. Wir tracken hier zusaetzlich den
# logischen Status, damit auf jedem off→on-Wechsel ein einmaliges
# WARNUNG-Log erscheint. Modul-globaler State, weil get_https_verify
# sowohl aus main() als auch aus dem 1-Hz-Probe-Tick aufgerufen wird;
# beide Stellen muessen sich auf denselben Status einigen.
_insecure_warning_active = False


def get_https_verify(cfg):
    """Liefert das verify-Argument fuer requests-Aufrufe und
    synchronisiert den urllib3-Warning-Status mit allow_insecure_https.

    Wird aus main()- und Probe-Loop aufgerufen, damit ein Toggle
    waehrend eines langen sleep_with_time_ticks(poll_interval) keine
    Warning-Floods erzeugt (Probe-Requests mit verify=False ohne
    Disable wuerden sonst InsecureRequestWarning fuer jeden Probe-
    Tick emittieren, bis main() das naechste Mal durchlaeuft)."""
    global _insecure_warning_active
    verify = not bool(cfg.get("allow_insecure_https"))
    if not verify and not _insecure_warning_active:
        urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
        requests.packages.urllib3.disable_warnings(
            requests.packages.urllib3.exceptions.InsecureRequestWarning
        )
        log("WARNUNG: TLS-Pruefung abgeschaltet (allow_insecure_https=true).")
        _insecure_warning_active = True
    elif verify:
        _insecure_warning_active = False
    return verify


def basename_from_entry(entry):
    # Basename = letzter Pfad-Segmentteil ohne Query-/Fragment-Anteil.
    # Bei vollstaendigen URLs (http://, https://) wird via urlsplit der
    # Path extrahiert, damit ?token=... nicht im Cache-Filename landet
    # und zwei URLs mit identischem Asset aber unterschiedlicher Query
    # auf denselben Cache-Slot fallen. Bei reinen Pfaden/Dateinamen
    # passiert string-mechanisch dasselbe.
    if "://" in entry:
        path = urlsplit(entry).path
    else:
        path = entry
    name = path.rsplit("/", 1)[-1].rsplit("\\", 1)[-1]
    # Percent-Encoding (z. B. "%C3%A4" -> "ä") aufloesen, damit der
    # lokale Cache-Filename in der gleichen Form vorliegt wie ein
    # direkt UTF-8 angegebener Eintrag — sonst wuerden gleicher
    # Inhalt unter zwei Encodings doppelt gecached.
    return unquote(name)


def parse_playlist(text, default_dur):
    # M3U und M3U8 sind syntaktisch identisch — der Unterschied liegt
    # nur im erwarteten Encoding (M3U: oft Latin-1/Win-1252; M3U8:
    # UTF-8). Encoding-Behandlung passiert im Caller via r.encoding.
    #
    # Eintraege koennen sein:
    #   * reiner Dateiname           "clip.mp4"
    #   * relativer Pfad             "videos/clip.mp4"
    #   * vollstaendige URL          "https://cdn.example.com/clip.mp4"
    # In allen Faellen ist der Basename die kanonische Cache-/Content-
    # Identitaet (siehe basename_from_entry); der Original-Eintrag wird
    # zusaetzlich als "url" gefuehrt und erst beim Download gegen die
    # effektive Basis-URL aufgeloest (zusammengesetzt aus playlist_url
    # und base_url, s. main()). Voraussetzung: der Inhaltslieferant
    # garantiert "gleicher Basename = gleicher Inhalt" (aufrufende
    # Server enforcen das).
    entries = []
    duration = default_dur
    for line in text.splitlines():
        line = line.strip()
        if line.startswith("#EXTINF:"):
            try:
                duration = int(line.split("#EXTINF:", 1)[1].split(",", 1)[0])
            except Exception:
                pass
        elif line and not line.startswith("#"):
            name = basename_from_entry(line)
            if name:
                entries.append({
                    "name":     name,
                    "url":      line,
                    "duration": duration,
                })
            duration = default_dur
    return entries


def slide_filename(name):
    return SLIDE_PREFIX + name


# Endungen, die als Video-Container interpretiert werden. Bewusst
# konservativ: info-beamer dokumentiert nur MP4 als unterstuetzten
# Container fuer resource.load_video; m4v ist derselbe Container mit
# anderem Suffix; mov teilt das ISO-BMFF-Boxen-Layout und wird vom
# MMAL-Demuxer in der Praxis akzeptiert. webm/mkv/avi sind in der
# info-beamer-Doku nirgendwo als unterstuetzt aufgefuehrt — Dateien
# mit diesen Endungen werden hier daher als "image" durchgereicht und
# wuerden in node.lua am resource.load_image scheitern (saubere
# Fehlermeldung statt undefiniertem Verhalten beim Video-Decode).
# Codec-Erwartung: H.264 fuer alle Pi-Versionen mit Hardware-Decoder;
# HEVC nur Pi 4+ ab info-beamer hosted v10. Abweichende Codecs in den
# zugelassenen Containern (z. B. HEVC-MP4 auf Pi 3) schlagen beim
# Decode-Versuch fehl — das ist Sache des Ablieferers.
# Identische Liste wie media_type_for in node.lua.
VIDEO_EXTENSIONS = ("mp4", "m4v", "mov")


def media_type(name):
    if "." not in name:
        return "image"
    ext = name.rsplit(".", 1)[-1].lower()
    if ext in VIDEO_EXTENSIONS:
        return "video"
    return "image"


def write_manifest(entries):
    out = {
        "slides": [
            {"file": slide_filename(e["name"]),
             "duration": e["duration"],
             "type": media_type(e["name"])}
            for e in entries
        ],
    }
    tmp = MANIFEST + ".tmp"
    with open(tmp, "w") as f:
        json.dump(out, f)
    os.rename(tmp, MANIFEST)


def download_to(url, dest, verify, timeout):
    r = requests.get(url, verify=verify, timeout=timeout, stream=True)
    r.raise_for_status()
    tmp = dest + ".tmp"
    with open(tmp, "wb") as f:
        for chunk in r.iter_content(chunk_size=65536):
            if chunk:
                f.write(chunk)
    os.rename(tmp, dest)


# ============================================================
# Zeit-Overlay: berechnet den aktuellen Zeit-Text im konfigurierten
# strftime-Format unter Beruecksichtigung der Timezone und schickt
# ihn per UDP-IPC an den Lua-Knoten (data_mapper-Path "time"). info-
# beamer hat bewusst keine zuverlaessige Wall-Clock-API in Lua, daher
# die Aufgabenteilung.
# ============================================================

# Cache, um pytz.timezone() nicht in jeder Iteration neu aufzurufen
# (das wuerde tzdata neu parsen).
_tz_cache = {}


def get_tz(name):
    if not name:
        return None  # Fallback auf Systemzeit
    cached = _tz_cache.get(name)
    if cached is not None:
        return cached
    try:
        tz = pytz.timezone(name)
        _tz_cache[name] = tz
        return tz
    except Exception:
        log("Unbekannte Zeitzone: %r — verwende Systemzeit." % name)
        _tz_cache[name] = False
        return None


def push_time(text):
    """Sendet den Zeit-Text per UDP an den info-beamer-Lua-Knoten
    (data_mapper-Path 'time'). Kein Disk-IO, eine syscall, ~µs Latenz."""
    payload = b"root/time:" + text.encode("utf-8")
    try:
        _ipc_sock.sendto(payload, (IB_HOST, IB_PORT))
    except Exception as e:
        log("Zeit-IPC fehlgeschlagen: %s" % e)


# ============================================================
# Audio-Stream-Probe: prueft per HTTP, ob die im Setup
# konfigurierte Stream-URL gerade erreichbar ist, und sendet das
# Ergebnis per UDP-IPC an den Lua-Knoten (data_mapper-Path
# 'audio_probe').
#
# Hintergrund: in info-beamer (hosted, stable-0016) gibt es einen
# bekannten SIGSEGV im Audio-Worker, sobald resource.load_audio mit
# einer URL aufgerufen wird, die der Server nicht oder nicht mehr
# bedient (404, DNS-Fail, Conn-Refused, Timeout, ...). Der Crash
# nimmt den ganzen info-beamer-Prozess mit; Watchdog startet neu;
# falls die URL weiter unerreichbar bleibt, entsteht eine Restart-
# Schleife im Sekundentakt — Bildschirm wird permanent schwarz, bis
# der Stream wieder antwortet. Aus Lua heraus laesst sich der Crash
# nicht abfangen (passiert im nativen Worker-Thread nach Rueckkehr
# von load_audio).
#
# Schutzmechanismus: bevor Lua resource.load_audio aufruft, muss von
# diesem Sidecar ein frischer 'audio_probe:ok' eingetroffen sein.
# Bei 'audio_probe:fail' blockiert Lua den (Re)load, sodass der
# Worker nie eine kaputte URL sieht.
#
# Probe-Methode: ein GET mit Range: bytes=0-0 und stream=True. Body
# wird nicht gelesen, Verbindung sofort geschlossen — minimaler
# Bandbreitenverbrauch. HEAD vermeiden wir bewusst, weil Icecast in
# der Praxis oft 405/501 darauf antwortet.
# ============================================================

# Probe-Intervall: ok-Fall 5 s, fail-Fall 3 s (schnellere Recovery).
# Probe-Timeout: 0.9 s. Der Probe laeuft synchron im
# sleep_with_time_ticks-Loop und blockiert dort die naechste Iteration
# entsprechend lange — bei <1 s bleibt der nominelle 1-Hz-Takt fuer
# das Time-IPC erhalten (eine einzelne Probe-Iteration ueberzieht
# das Sleep-Budget nicht). Server, die laenger als 0.9 s zur Antwort
# brauchen, werden als fail markiert; in der Praxis triggern solche
# Server auch fuer load_audio Timeouts und sollten nicht angesprochen
# werden.
_PROBE_INTERVAL_OK   = 5.0
_PROBE_INTERVAL_FAIL = 3.0
_PROBE_TIMEOUT       = 0.9

_audio_probe_state = {
    "next_at":  0.0,
    "last_url": None,
}


def push_audio_probe(result, url):
    # Format: "ok:<url>" oder "fail:<url>". Lua matcht die URL gegen
    # audio_stream.url, damit ein frisches Probe-Resultat fuer eine
    # alte URL nicht versehentlich auf eine zwischenzeitlich
    # geaenderte URL angewendet wird (Race-Schutz bei Setup-Aenderung
    # im stale_after-Fenster). URL wird roh (Konfig-Form) gesendet
    # — Lua's audio_stream.url ist ebenfalls roh, sanitize_url wird
    # erst beim load_audio angewendet.
    payload = (b"root/audio_probe:"
               + result.encode("ascii") + b":"
               + url.encode("utf-8"))
    try:
        _ipc_sock.sendto(payload, (IB_HOST, IB_PORT))
    except Exception as e:
        log("Audio-Probe-IPC fehlgeschlagen: %s" % e)


def sanitize_url(url):
    """Percent-kodiert UTF-8-Bytes >= 0x80. Identisches Verhalten wie
    sanitize_url in node.lua: Probe und resource.load_audio sehen so
    dieselbe URL — sonst koennten beide Pfade fuer nicht-ASCII URLs
    auseinanderlaufen (Probe meldet fail wegen 404 auf unkodiertem
    Pfad, obwohl load_audio mit kodierter URL funktionieren wuerde,
    der Stream waere dauerhaft geblockt). Idempotent: bereits
    prozentkodierte URLs bleiben unveraendert."""
    if not url:
        return url
    if isinstance(url, bytes):
        data = url
    else:
        data = url.encode("utf-8")
    out = []
    for b in data:
        # Py2: bytes-Iteration liefert str(len=1); Py3: liefert int.
        n = b if isinstance(b, int) else ord(b)
        if n >= 0x80:
            out.append("%%%02X" % n)
        else:
            out.append(chr(n))
    return "".join(out)


def probe_audio_url(url, verify):
    try:
        r = requests.get(
            sanitize_url(url),
            verify=verify,
            timeout=_PROBE_TIMEOUT,
            stream=True,
            headers={"Range": "bytes=0-0"},
        )
        try:
            r.close()
        except Exception:
            pass
        # Konservativ: nur Status <400 als ok werten. Auth-Fehler
        # (401/403) und 4xx/5xx sind aus Sicht von load_audio
        # ebenfalls fehlgeschlagene Opens und koennen den SIGSEGV
        # triggern — daher als fail markieren.
        if r.status_code < 400:
            return "ok"
        return "fail"
    except Exception:
        return "fail"


def maybe_probe_audio_stream(cfg):
    enabled = bool(cfg.get("audio_stream_enabled"))
    url     = (cfg.get("audio_stream_url") or "").strip()

    # Stream deaktiviert oder URL leer → State zuruecksetzen, damit
    # bei (Wieder-)Aktivierung sofort eine neue Probe laeuft.
    # Zusaetzlich beim Aktiv→Inaktiv-Uebergang einen invalidierenden
    # fail-Push an Lua schicken: sonst koennte ein noch frisches
    # "ok" der alten URL bei einem schnellen Disable→Enable-Toggle
    # (oder URL leeren+wieder eintragen) innerhalb stale_after fuer
    # die wiederaktivierte URL gelten und load_audio sofort
    # ausloesen — genau der Pfad, den der Probe-Gate verhindern soll.
    if not enabled or not url:
        if _audio_probe_state["last_url"] is not None:
            push_audio_probe("fail", _audio_probe_state["last_url"])
        _audio_probe_state["next_at"]  = 0.0
        _audio_probe_state["last_url"] = None
        return

    now = time.time()
    # URL-Wechsel erzwingt sofortige Neu-Probe (alter Probe-Timer
    # bezog sich auf die alte URL).
    if url != _audio_probe_state["last_url"]:
        _audio_probe_state["next_at"] = 0.0
    if now < _audio_probe_state["next_at"]:
        return

    verify = get_https_verify(cfg)
    result = probe_audio_url(url, verify)
    push_audio_probe(result, url)

    _audio_probe_state["last_url"] = url
    interval = _PROBE_INTERVAL_OK if result == "ok" else _PROBE_INTERVAL_FAIL
    _audio_probe_state["next_at"] = now + interval


def update_time(cfg):
    # Wenn das Overlay deaktiviert ist, schicken wir nichts — Lua
    # zeichnet es ohnehin nicht.
    if not cfg.get("time_enabled"):
        return

    fmt = cfg.get("time_format") or "%H:%M"
    tz_name = (cfg.get("time_timezone") or "").strip()

    tz = get_tz(tz_name) if tz_name else None
    if tz is False:  # bereits als ungueltig markiert
        tz = None

    if tz is not None:
        now = datetime.datetime.now(tz)
    else:
        now = datetime.datetime.now()

    try:
        text = now.strftime(fmt)
    except Exception as e:
        log("strftime-Fehler (Format %r): %s" % (fmt, e))
        return

    if isinstance(text, bytes):
        text = text.decode("utf-8", "replace")

    # Jede Sekunde pushen, auch wenn sich der Text nicht geaendert
    # hat. Sonst koennte ein gerade neu gestarteter Lua-Knoten bei
    # einem Format wie %H:%M bis zu einer Minute warten, bis der
    # naechste Minutenwechsel den naechsten Send ausloest. Mit
    # 1 Hz-Heartbeat hat Lua spaetestens nach 1 s einen frischen
    # Wert — UDP-Loopback ist quasi kostenlos.
    push_time(text)


def sleep_with_time_ticks(total_seconds):
    """Schlaeft total_seconds, pusht den Zeit-Text grob im 1-Hz-Takt
    via UDP an den Lua-Knoten — sodass das Zeit-Overlay nicht erst
    nach poll_interval aktualisiert wird. Re-loaded config jede
    Iteration, damit Format-/Timezone-Aenderungen latenzarm
    einschlagen.

    Der Takt ist annaehernd 1 Hz: ein synchrones Audio-Probe
    (s. _PROBE_TIMEOUT, derzeit 0.9 s) kann eine Iteration leicht
    verlaengern, bleibt aber unter der 1-s-Sleep-Schranke. Sekunden-
    genaue Zeit-Formate koennen daher gelegentlich (~alle 5 s) leicht
    nachhinken, bei %H:%M unmerklich."""
    end = time.time() + total_seconds
    while True:
        cfg = load_config()
        update_time(cfg)
        maybe_probe_audio_stream(cfg)
        remaining = end - time.time()
        if remaining <= 0:
            return
        time.sleep(min(1.0, max(0.1, remaining)))


def main():
    last_manifest_hash = None

    while True:
        try:
            cfg = load_config()
            # Zeit jede Hauptiteration auch frisch schreiben (zusaetzlich
            # zum 1-Hz-Tick im sleep_with_time_ticks).
            update_time(cfg)
            playlist_url   = (cfg.get("playlist_url") or "").strip()
            cfg_base_url   = (cfg.get("base_url")     or "").strip()
            default_dur    = int(cfg.get("default_duration") or 10)
            poll_interval  = max(5,  int(cfg.get("poll_interval")  or 60))
            retry_interval = max(5,  int(cfg.get("retry_interval") or 30))
            # verify + Warning-Handling zentral via get_https_verify,
            # damit Probe-Loop (im sleep_with_time_ticks) und Haupt-
            # Loop denselben Warning-Status sehen.
            verify         = get_https_verify(cfg)

            if not playlist_url:
                log("playlist_url nicht konfiguriert.")
                sleep_with_time_ticks(retry_interval)
                continue

            # Effektive Basis-URL fuer Playlist-Eintraege berechnen.
            # urljoin-Kette deckt alle drei base_url-Faelle ohne
            # Fallunterscheidung ab:
            #   leer       -> urljoin(playlist_url, "./") -> Playlist-Dir
            #   relativ    -> urljoin(playlist_url, base_url) -> aufgeloest gegen Playlist-Dir
            #   absolut    -> urljoin(playlist_url, base_url) -> base_url (urljoin erkennt http/https)
            # Trailing "/" auf relative Werte forcieren, damit das
            # nachfolgende urljoin gegen Eintraege als Verzeichnis
            # behandelt wird ("subdir" wuerde sonst durch das
            # naechste urljoin ueberschrieben statt darunter
            # gehaengt).
            if cfg_base_url and "://" not in cfg_base_url \
                    and not cfg_base_url.endswith("/"):
                cfg_base_url += "/"
            if cfg_base_url:
                base_url = urljoin(playlist_url, cfg_base_url)
            else:
                base_url = urljoin(playlist_url, "./")

            # Playlist holen. Wenn der Server keinen Charset-Header
            # mitliefert, raet requests fuer text/*-Content-Types
            # standardmaessig ISO-8859-1 — das macht UTF-8-Umlaute in
            # Dateinamen kaputt. apparent_encoding nutzt chardet zur
            # Erkennung anhand der Bytes; deckt M3U (Latin-1) und M3U8
            # (UTF-8) gleichermassen ab. Nur ueberschreiben, wenn der
            # Server explizit kein charset gesetzt hat.
            try:
                r = requests.get(playlist_url, verify=verify, timeout=10)
                r.raise_for_status()
                if r.encoding is None or "charset" not in r.headers.get("Content-Type", "").lower():
                    r.encoding = r.apparent_encoding or "utf-8"
                playlist_text = r.text
            except Exception as e:
                log("Playlist-Fetch fehlgeschlagen: %s" % e)
                sleep_with_time_ticks(retry_interval)
                continue

            entries = parse_playlist(playlist_text, default_dur)

            if not entries:
                if last_manifest_hash != "EMPTY":
                    write_manifest([])
                    last_manifest_hash = "EMPTY"
                    log("Playlist leer.")
                sleep_with_time_ticks(retry_interval)
                continue

            # Fehlende Folien herunterladen. Filenames sind content-
            # adressiert (gleicher Name == gleicher Inhalt), daher reicht
            # eine Existenzpruefung im Cache.
            #
            # Vor jedem tatsaechlichen Download (nicht bei Cache-Hits)
            # loest sleep_with_time_ticks(0) einen Zeit- und Audio-
            # Probe-Tick aus, damit der Renderer auch waehrend
            # laengerer Download-Phasen frische Heartbeats bekommt —
            # sonst wuerde die Audio-Probe Lua-seitig stale
            # (>stale_after, derzeit 60 s) und Reload pausiert unnoetig.
            # Worst Case: ein einzelner Download blockiert bis 30 s —
            # innerhalb dieses Fensters laeuft kein Tick, aber der
            # Renderer erholt sich automatisch beim naechsten Tick
            # zwischen den Downloads.
            for entry in entries:
                local = slide_filename(entry["name"])
                if os.path.exists(local):
                    continue
                sleep_with_time_ticks(0)
                # base_url wurde oben aus playlist_url + cfg_base_url
                # zur effektiven Basis aufgeloest. urljoin gegen den
                # Playlist-Eintrag verhaelt sich dann nach RFC 3986:
                #   * absolute URL (http://, https://) -> bleibt unveraendert
                #   * server-absoluter Pfad ("/x.mp4") -> base_url-Host + Pfad
                #   * relativer Pfad/Filename          -> base_url + entry
                # Damit funktionieren reine Filenames, Unterverzeichnisse
                # und vollstaendige Fremd-Server-URLs gleichermassen,
                # unabhaengig davon, ob cfg_base_url leer, relativ oder
                # absolut konfiguriert wurde.
                download_url = urljoin(base_url, entry["url"])
                try:
                    download_to(download_url, local, verify, 30)
                except Exception as e:
                    log("Folie-Download fehlgeschlagen %s (%s): %s" %
                        (entry["name"], download_url, e))

            # Cache aufraeumen: entferne nur Files mit unserem Praefix,
            # die nicht mehr in der aktuellen Playlist sind, sowie
            # .tmp-Reste aus abgebrochenen Downloads. Knoten-eigene
            # Dateien (node.lua, node.json, empty.png, ...) werden durch
            # die Praefix-Pruefung verschont. Laeuft nur nach
            # erfolgreichem Playlist-Fetch (HTTP-Fehler springen vorher
            # per `continue`), daher kein versehentlicher Komplett-Wipe
            # wegen Netzproblem.
            keep = set(slide_filename(e["name"]) for e in entries)
            removed = 0
            try:
                for fname in os.listdir("."):
                    if not fname.startswith(SLIDE_PREFIX):
                        continue
                    if fname.endswith(".tmp") or fname not in keep:
                        try:
                            os.remove(fname)
                            removed += 1
                        except OSError:
                            pass
            except OSError as e:
                log("Cache-GC fehlgeschlagen: %s" % e)
            if removed:
                log("Cache aufgeraeumt: %d Datei(en) entfernt." % removed)

            available = [
                e for e in entries
                if os.path.exists(slide_filename(e["name"]))
            ]

            if not available:
                log("Keine Folie ladbar.")
                sleep_with_time_ticks(retry_interval)
                continue

            # Hash ueber tatsaechlich verfuegbare Folien — auch bei
            # gleichem Playlist-Body neu schreiben, falls neue Downloads
            # hinzugekommen sind.
            sig = "|".join("%s:%d" % (e["name"], e["duration"]) for e in available)
            available_hash = hashlib.sha1(sig.encode("utf-8")).hexdigest()

            if available_hash != last_manifest_hash:
                write_manifest(available)
                last_manifest_hash = available_hash
                log("Manifest aktualisiert: %d Folien." % len(available))

            sleep_with_time_ticks(poll_interval)
        except KeyboardInterrupt:
            log("beendet.")
            return
        except Exception:
            log("Unerwarteter Fehler:\n%s" % traceback.format_exc())
            sleep_with_time_ticks(5)


if __name__ == "__main__":
    main()
