#!/usr/bin/python2.7
# -*- coding: utf-8 -*-
#
# Infotext Player - Service-Sidecar
#
# info-beamer-Lua-Knoten koennen kein HTTP. Dieser Sidecar laeuft als
# Python-Prozess parallel zum Knoten, pollt regelmaessig die M3U8-
# Playlist + Folien-Bilder vom Infotext-Server und schreibt die
# heruntergeladenen Folien direkt in das Knoten-Verzeichnis. Eine
# manifest.json mit der aktuellen Folienliste wird via util.json_watch
# vom node.lua beobachtet.
#
# Folien-Files erhalten den Praefix SLIDE_PREFIX, damit sie sich klar
# von den Knoten-eigenen Dateien (node.lua, node.json, empty.png, ...)
# unterscheiden lassen. Ein Cache-Unterverzeichnis vermeiden wir, weil
# info-beamer Folien aus zur Laufzeit befuellten Subdirs nicht
# zuverlaessig findet (Subdir = Child-Node).
#
# Konfiguration kommt aus config.json (gleicher Pfad wie fuer Lua).
# Der Service liest sie in jeder Schleifen-Iteration neu, damit
# Setup-Aenderungen ohne Neustart wirken.

import os
import sys
import json
import time
import socket
import hashlib
import traceback
import datetime

import requests
import urllib3
import pytz

SLIDE_PREFIX = "slide_"
MANIFEST     = "manifest.json"
CONFIG       = "config.json"

# UDP-IPC zu info-beamer auf dem Standard-Port. Wird fuer das Push
# des Zeit-Texts an den Lua-Knoten verwendet, statt eine Datei auf
# der SD-Karte zu schreiben (~86k Writes/Tag bei sekundengenauer
# Anzeige würden die SD unnoetig belasten).
IB_HOST   = "127.0.0.1"
IB_PORT   = 4444
_ipc_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)


def log(msg):
    sys.stderr.write("[infotext-service] %s\n" % msg)
    sys.stderr.flush()


def load_config():
    try:
        with open(CONFIG) as f:
            return json.load(f)
    except Exception as e:
        log("config.json konnte nicht gelesen werden: %s" % e)
        return {}


def parse_playlist(text, default_dur):
    # M3U und M3U8 sind syntaktisch identisch — der Unterschied liegt
    # nur im erwarteten Encoding (M3U: oft Latin-1/Win-1252; M3U8:
    # UTF-8). Encoding-Behandlung passiert im Caller via r.encoding.
    entries = []
    duration = default_dur
    for line in text.splitlines():
        line = line.strip()
        if line.startswith("#EXTINF:"):
            try:
                duration = int(line.split("#EXTINF:", 1)[1].split(",", 1)[0])
            except Exception:
                pass
        elif line and not line.startswith("#"):
            # Nur Dateiname, falls die Playlist absolute oder relative
            # Pfade enthaelt.
            name = line.rsplit("/", 1)[-1].rsplit("\\", 1)[-1]
            if name:
                entries.append({"name": name, "duration": duration})
            duration = default_dur
    return entries


def slide_filename(name):
    return SLIDE_PREFIX + name


# Endungen, die als Video-Container interpretiert werden. Bewusst
# konservativ: info-beamer dokumentiert nur MP4 als unterstuetzten
# Container fuer resource.load_video; m4v ist derselbe Container mit
# anderem Suffix; mov teilt das ISO-BMFF-Boxen-Layout und wird vom
# MMAL-Demuxer in der Praxis akzeptiert. webm/mkv/avi sind in der
# info-beamer-Doku nirgendwo als unterstuetzt aufgefuehrt — Dateien
# mit diesen Endungen werden hier daher als "image" durchgereicht und
# wuerden in node.lua am resource.load_image scheitern (saubere
# Fehlermeldung statt undefiniertem Verhalten beim Video-Decode).
# Codec-Erwartung: H.264 fuer alle Pi-Versionen mit Hardware-Decoder;
# HEVC nur Pi 4+ ab info-beamer hosted v10. Abweichende Codecs in den
# zugelassenen Containern (z. B. HEVC-MP4 auf Pi 3) schlagen beim
# Decode-Versuch fehl — das ist Sache des Ablieferers.
# Identische Liste wie media_type_for in node.lua.
VIDEO_EXTENSIONS = ("mp4", "m4v", "mov")


def media_type(name):
    if "." not in name:
        return "image"
    ext = name.rsplit(".", 1)[-1].lower()
    if ext in VIDEO_EXTENSIONS:
        return "video"
    return "image"


def write_manifest(entries):
    out = {
        "slides": [
            {"file": slide_filename(e["name"]),
             "duration": e["duration"],
             "type": media_type(e["name"])}
            for e in entries
        ],
    }
    tmp = MANIFEST + ".tmp"
    with open(tmp, "w") as f:
        json.dump(out, f)
    os.rename(tmp, MANIFEST)


def download_to(url, dest, verify, timeout):
    r = requests.get(url, verify=verify, timeout=timeout, stream=True)
    r.raise_for_status()
    tmp = dest + ".tmp"
    with open(tmp, "wb") as f:
        for chunk in r.iter_content(chunk_size=65536):
            if chunk:
                f.write(chunk)
    os.rename(tmp, dest)


# ============================================================
# Zeit-Overlay: berechnet den aktuellen Zeit-Text im konfigurierten
# strftime-Format unter Beruecksichtigung der Timezone und schickt
# ihn per UDP-IPC an den Lua-Knoten (data_mapper-Path "time"). info-
# beamer hat bewusst keine zuverlaessige Wall-Clock-API in Lua, daher
# die Aufgabenteilung.
# ============================================================

# Cache, um pytz.timezone() nicht in jeder Iteration neu aufzurufen
# (das wuerde tzdata neu parsen).
_tz_cache = {}


def get_tz(name):
    if not name:
        return None  # Fallback auf Systemzeit
    cached = _tz_cache.get(name)
    if cached is not None:
        return cached
    try:
        tz = pytz.timezone(name)
        _tz_cache[name] = tz
        return tz
    except Exception:
        log("Unbekannte Zeitzone: %r — verwende Systemzeit." % name)
        _tz_cache[name] = False
        return None


def push_time(text):
    """Sendet den Zeit-Text per UDP an den info-beamer-Lua-Knoten
    (data_mapper-Path 'time'). Kein Disk-IO, eine syscall, ~µs Latenz."""
    payload = b"root/time:" + text.encode("utf-8")
    try:
        _ipc_sock.sendto(payload, (IB_HOST, IB_PORT))
    except Exception as e:
        log("Zeit-IPC fehlgeschlagen: %s" % e)


def update_time(cfg):
    # Wenn das Overlay deaktiviert ist, schicken wir nichts — Lua
    # zeichnet es ohnehin nicht.
    if not cfg.get("time_enabled"):
        return

    fmt = cfg.get("time_format") or "%H:%M"
    tz_name = (cfg.get("time_timezone") or "").strip()

    tz = get_tz(tz_name) if tz_name else None
    if tz is False:  # bereits als ungueltig markiert
        tz = None

    if tz is not None:
        now = datetime.datetime.now(tz)
    else:
        now = datetime.datetime.now()

    try:
        text = now.strftime(fmt)
    except Exception as e:
        log("strftime-Fehler (Format %r): %s" % (fmt, e))
        return

    if isinstance(text, bytes):
        text = text.decode("utf-8", "replace")

    # Jede Sekunde pushen, auch wenn sich der Text nicht geaendert
    # hat. Sonst koennte ein gerade neu gestarteter Lua-Knoten bei
    # einem Format wie %H:%M bis zu einer Minute warten, bis der
    # naechste Minutenwechsel den naechsten Send ausloest. Mit
    # 1 Hz-Heartbeat hat Lua spaetestens nach 1 s einen frischen
    # Wert — UDP-Loopback ist quasi kostenlos.
    push_time(text)


def sleep_with_time_ticks(total_seconds):
    """Schlaeft total_seconds, pusht den Zeit-Text jede Sekunde via
    UDP an den Lua-Knoten — sodass das Zeit-Overlay nicht erst nach
    poll_interval aktualisiert wird. Re-loaded config jede Sekunde,
    damit Format-/Timezone-Aenderungen latenzarm einschlagen."""
    end = time.time() + total_seconds
    while True:
        cfg = load_config()
        update_time(cfg)
        remaining = end - time.time()
        if remaining <= 0:
            return
        time.sleep(min(1.0, max(0.1, remaining)))


def main():
    last_manifest_hash = None
    insecure_warning_active = False

    while True:
        try:
            cfg = load_config()
            # Zeit jede Hauptiteration auch frisch schreiben (zusaetzlich
            # zum 1-Hz-Tick im sleep_with_time_ticks).
            update_time(cfg)
            playlist_url   = (cfg.get("playlist_url")    or "").strip()
            base_url       = (cfg.get("folien_base_url") or "").strip()
            default_dur    = int(cfg.get("default_duration") or 10)
            poll_interval  = max(5,  int(cfg.get("poll_interval")  or 60))
            retry_interval = max(5,  int(cfg.get("retry_interval") or 30))
            verify         = not bool(cfg.get("allow_insecure_https"))

            # urllib3-Warnings bei jeder Konfig-Aenderung (de)aktivieren.
            if not verify and not insecure_warning_active:
                urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
                requests.packages.urllib3.disable_warnings(
                    requests.packages.urllib3.exceptions.InsecureRequestWarning
                )
                log("WARNUNG: TLS-Pruefung abgeschaltet (allow_insecure_https=true).")
                insecure_warning_active = True
            elif verify:
                insecure_warning_active = False

            if not playlist_url or not base_url:
                log("playlist_url oder folien_base_url nicht konfiguriert.")
                sleep_with_time_ticks(retry_interval)
                continue

            if not base_url.endswith("/"):
                base_url += "/"

            # Playlist holen. Wenn der Server keinen Charset-Header
            # mitliefert, raet requests fuer text/*-Content-Types
            # standardmaessig ISO-8859-1 — das macht UTF-8-Umlaute in
            # Dateinamen kaputt. apparent_encoding nutzt chardet zur
            # Erkennung anhand der Bytes; deckt M3U (Latin-1) und M3U8
            # (UTF-8) gleichermassen ab. Nur ueberschreiben, wenn der
            # Server explizit kein charset gesetzt hat.
            try:
                r = requests.get(playlist_url, verify=verify, timeout=10)
                r.raise_for_status()
                if r.encoding is None or "charset" not in r.headers.get("Content-Type", "").lower():
                    r.encoding = r.apparent_encoding or "utf-8"
                playlist_text = r.text
            except Exception as e:
                log("Playlist-Fetch fehlgeschlagen: %s" % e)
                sleep_with_time_ticks(retry_interval)
                continue

            entries = parse_playlist(playlist_text, default_dur)

            if not entries:
                if last_manifest_hash != "EMPTY":
                    write_manifest([])
                    last_manifest_hash = "EMPTY"
                    log("Playlist leer.")
                sleep_with_time_ticks(retry_interval)
                continue

            # Fehlende Folien herunterladen. Filenames sind content-
            # adressiert (gleicher Name == gleicher Inhalt), daher reicht
            # eine Existenzpruefung im Cache.
            for entry in entries:
                local = slide_filename(entry["name"])
                if os.path.exists(local):
                    continue
                try:
                    download_to(base_url + entry["name"], local, verify, 30)
                except Exception as e:
                    log("Folie-Download fehlgeschlagen %s: %s" %
                        (entry["name"], e))

            # Cache aufraeumen: entferne nur Files mit unserem Praefix,
            # die nicht mehr in der aktuellen Playlist sind, sowie
            # .tmp-Reste aus abgebrochenen Downloads. Knoten-eigene
            # Dateien (node.lua, node.json, empty.png, ...) werden durch
            # die Praefix-Pruefung verschont. Laeuft nur nach
            # erfolgreichem Playlist-Fetch (HTTP-Fehler springen vorher
            # per `continue`), daher kein versehentlicher Komplett-Wipe
            # wegen Netzproblem.
            keep = set(slide_filename(e["name"]) for e in entries)
            removed = 0
            try:
                for fname in os.listdir("."):
                    if not fname.startswith(SLIDE_PREFIX):
                        continue
                    if fname.endswith(".tmp") or fname not in keep:
                        try:
                            os.remove(fname)
                            removed += 1
                        except OSError:
                            pass
            except OSError as e:
                log("Cache-GC fehlgeschlagen: %s" % e)
            if removed:
                log("Cache aufgeraeumt: %d Datei(en) entfernt." % removed)

            available = [
                e for e in entries
                if os.path.exists(slide_filename(e["name"]))
            ]

            if not available:
                log("Keine Folie ladbar.")
                sleep_with_time_ticks(retry_interval)
                continue

            # Hash ueber tatsaechlich verfuegbare Folien — auch bei
            # gleichem Playlist-Body neu schreiben, falls neue Downloads
            # hinzugekommen sind.
            sig = "|".join("%s:%d" % (e["name"], e["duration"]) for e in available)
            available_hash = hashlib.sha1(sig.encode("utf-8")).hexdigest()

            if available_hash != last_manifest_hash:
                write_manifest(available)
                last_manifest_hash = available_hash
                log("Manifest aktualisiert: %d Folien." % len(available))

            sleep_with_time_ticks(poll_interval)
        except KeyboardInterrupt:
            log("beendet.")
            return
        except Exception:
            log("Unerwarteter Fehler:\n%s" % traceback.format_exc())
            sleep_with_time_ticks(5)


if __name__ == "__main__":
    main()
